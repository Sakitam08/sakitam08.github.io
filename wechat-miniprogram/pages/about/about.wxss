/* pages/about/about.wxss */
.about {
  padding: 160rpx 0;
  background: #f8f9fa;
}

.about-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 100rpx;
}

.about-image {
  text-align: center;
}

.avatar-placeholder {
  display: inline-block;
  border-radius: 50%;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2);
}

.about-text {
  width: 100%;
  max-width: 800rpx;
  text-align: center;
}

.about-title {
  font-size: 56rpx;
  margin-bottom: 40rpx;
  color: #667eea;
  display: block;
}

.about-desc {
  margin-bottom: 30rpx;
  color: #666;
  line-height: 1.8;
  display: block;
}

.skills {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
  flex-wrap: wrap;
  justify-content: center;
}

.skill-tag {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

/* 响应式设计 */
@media (min-width: 768px) {
  .about-content {
    flex-direction: row;
    align-items: flex-start;
  }
  
  .about-text {
    text-align: left;
  }
  
  .skills {
    justify-content: flex-start;
  }
}