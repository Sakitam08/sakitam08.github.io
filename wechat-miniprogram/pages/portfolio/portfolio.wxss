/* pages/portfolio/portfolio.wxss */
.portfolio {
  padding: 160rpx 0;
  background: #f8f9fa;
}

.portfolio-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(400rpx, 1fr));
  gap: 60rpx;
}

.portfolio-item {
  background: white;
  border-radius: 30rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.portfolio-item:hover {
  transform: translateY(-20rpx);
  box-shadow: 0 30rpx 80rpx rgba(0, 0, 0, 0.2);
}

.portfolio-image {
  height: 400rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

.portfolio-info {
  padding: 40rpx;
}

.portfolio-title {
  font-size: 36rpx;
  margin-bottom: 20rpx;
  color: #667eea;
  display: block;
}

.portfolio-subtitle {
  color: #666;
  font-size: 28rpx;
  margin-bottom: 20rpx;
  display: block;
}

.portfolio-note {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #f0f0f0;
  display: block;
}

.modal {
  display: none;
  position: fixed;
  z-index: 1000;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  overflow: auto;
  background-color: rgba(0, 0, 0, 0.9);
  align-items: center;
  justify-content: center;
}

.modal.show {
  display: flex;
}

.modal-content {
  position: relative;
  max-width: 90%;
  max-height: 90%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content image {
  width: 100%;
  height: auto;
  max-height: 80vh;
  object-fit: contain;
}

.close-modal {
  position: absolute;
  top: -80rpx;
  right: 0;
  color: white;
  font-size: 80rpx;
  font-weight: bold;
  cursor: pointer;
  transition: color 0.3s ease;
}

.close-modal:hover,
.close-modal:focus {
  color: #667eea;
  text-decoration: none;
}

/* 响应式设计 */
@media (max-width: 768px) {
  .portfolio-grid {
    grid-template-columns: 1fr;
  }
  
  .portfolio-title {
    font-size: 32rpx;
  }
}