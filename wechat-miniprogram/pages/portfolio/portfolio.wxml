<!--pages/portfolio/portfolio.wxml-->
<view class="portfolio">
  <view class="container">
    <text class="section-title">技术练习案例</text>
    <text class="section-subtitle">更多案例持续更新中...</text>
    <view class="portfolio-grid">
      <view class="portfolio-item">
        <view class="portfolio-image" bindtap="previewImage" data-src="/images/1.png">
          <image src="/images/1.png" mode="aspectFill" style="width: 100%; height: 100%;"></image>
        </view>
        <view class="portfolio-info">
          <text class="portfolio-title">汽车 3D 建模练习</text>
          <text class="portfolio-subtitle">白橙跑车</text>
          <text class="portfolio-note">素材来源于网络，仅用于技术演示，非商用，版权归原作者所有</text>
        </view>
      </view>
      <view class="portfolio-item">
        <view class="portfolio-image" bindtap="previewImage" data-src="/images/2.png">
          <image src="/images/2.png" mode="aspectFill" style="width: 100%; height: 100%;"></image>
        </view>
        <view class="portfolio-info">
          <text class="portfolio-title">汽车渲染与材质表现练习</text>
          <text class="portfolio-subtitle">黑蓝跑车</text>
          <text class="portfolio-note">素材来源于网络，仅用于技术演示，非商用，版权归原作者所有</text>
        </view>
      </view>
      <view class="portfolio-item">
        <view class="portfolio-image" bindtap="previewImage" data-src="/images/3.png">
          <image src="/images/3.png" mode="aspectFill" style="width: 100%; height: 100%;"></image>
        </view>
        <view class="portfolio-info">
          <text class="portfolio-title">建筑场景建模练习</text>
          <text class="portfolio-subtitle">小房子</text>
          <text class="portfolio-note">素材来源于网络，仅用于技术演示，非商用，版权归原作者所有</text>
        </view>
      </view>
      <view class="portfolio-item">
        <view class="portfolio-image" bindtap="previewImage" data-src="/images/4.png">
          <image src="/images/4.png" mode="aspectFill" style="width: 100%; height: 100%;"></image>
        </view>
        <view class="portfolio-info">
          <text class="portfolio-title">角色建模与姿态设计练习</text>
          <text class="portfolio-subtitle">坐姿人物</text>
          <text class="portfolio-note">素材来源于网络，仅用于技术演示，非商用，版权归原作者所有</text>
        </view>
      </view>
      <view class="portfolio-item">
        <view class="portfolio-image" bindtap="previewImage" data-src="/images/5.png">
          <image src="/images/5.png" mode="aspectFill" style="width: 100%; height: 100%;"></image>
        </view>
        <view class="portfolio-info">
          <text class="portfolio-title">网站项目版本管理与协作</text>
          <text class="portfolio-subtitle">Gitee 仓库</text>
          <text class="portfolio-note">素材来源于网络，仅用于技术演示，非商用，版权归原作者所有</text>
        </view>
      </view>
      <view class="portfolio-item">
        <view class="portfolio-image" bindtap="previewImage" data-src="/images/6.png">
          <image src="/images/6.png" mode="aspectFill" style="width: 100%; height: 100%;"></image>
        </view>
        <view class="portfolio-info">
          <text class="portfolio-title">3D 建模接单案例展示</text>
          <text class="portfolio-subtitle">闲鱼 3D 建模页</text>
          <text class="portfolio-note">素材来源于网络，仅用于技术演示，非商用，版权归原作者所有</text>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 图片预览模态框 -->
<view class="modal {{showModal ? 'show' : ''}}">
  <view class="modal-content">
    <view class="close-modal" bindtap="closeModal">&times;</view>
    <image src="{{previewImageSrc}}" mode="aspectFit" style="width: 100%; height: auto;"></image>
  </view>
</view>