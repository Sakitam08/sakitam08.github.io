/* pages/index/index.wxss */
.hero {
  min-height: 100vh;
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  position: relative;
  overflow: hidden;
}

.hero::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><circle cx="50" cy="50" r="40" fill="rgba(255,255,255,0.1)"/></svg>') repeat;
  background-size: 200px;
  animation: float 20s infinite linear;
}

@keyframes float {
  0% { transform: translateY(0) rotate(0deg); }
  100% { transform: translateY(-100px) rotate(360deg); }
}

.hero-content {
  text-align: center;
  color: white;
  z-index: 1;
}

.hero-title {
  font-size: 96rpx;
  margin-bottom: 40rpx;
  line-height: 1.2;
  display: block;
}

.hero-subtitle {
  font-size: 40rpx;
  margin-bottom: 80rpx;
  opacity: 0.9;
  display: block;
}

.hero-buttons {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
}

.btn {
  display: inline-block;
  padding: 24rpx 60rpx;
  border-radius: 60rpx;
  text-decoration: none;
  font-weight: 600;
  transition: all 0.3s ease;
  margin: 20rpx;
  cursor: pointer;
}

.btn-primary {
  background: white;
  color: #667eea;
}

.btn-primary:hover {
  transform: translateY(-6rpx);
  box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.2);
}

.btn-secondary {
  background: transparent;
  color: white;
  border: 2rpx solid white;
}

.btn-secondary:hover {
  background: white;
  color: #667eea;
  transform: translateY(-6rpx);
}

/* 响应式设计 */
@media (max-width: 768px) {
  .hero-title {
    font-size: 64rpx;
  }
  
  .hero-subtitle {
    font-size: 32rpx;
  }
  
  .btn {
    padding: 20rpx 50rpx;
    font-size: 28rpx;
  }
}