/* 全局样式 */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

:root {
  --primary-color: #667eea;
  --secondary-color: #764ba2;
  --accent-color: #f093fb;
  --text-color: #333;
  --light-text: #666;
  --bg-color: #fff;
  --light-bg: #f8f9fa;
  --dark-bg: #2d3748;
  --gradient: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
}

page {
  font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  line-height: 1.6;
  color: var(--text-color);
  background-color: var(--bg-color);
  overflow-x: hidden;
}

.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 20px;
}

.section-title {
  text-align: center;
  font-size: 36rpx;
  margin-bottom: 50rpx;
  color: var(--primary-color);
}

.section-subtitle {
  text-align: center;
  color: var(--light-text);
  margin-bottom: 40rpx;
  font-size: 28rpx;
}

.btn {
  display: inline-block;
  padding: 24rpx 60rpx;
  border-radius: 60rpx;
  text-decoration: none;
  font-weight: 600;
  transition: all 0.3s ease;
  margin: 20rpx;
  cursor: pointer;
}

.btn-primary {
  background: white;
  color: var(--primary-color);
}

.btn-secondary {
  background: transparent;
  color: white;
  border: 2rpx solid white;
}

.card-base {
  background: white;
  border-radius: 30rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.card-base:hover {
  transform: translateY(-20rpx);
  box-shadow: 0 30rpx 80rpx rgba(0, 0, 0, 0.2);
}

.service-card {
  background: white;
  border-radius: 30rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
  padding: 80rpx 60rpx;
  text-align: center;
}

.service-card:hover {
  transform: translateY(-20rpx);
  box-shadow: 0 30rpx 80rpx rgba(0, 0, 0, 0.2);
}

.service-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
}

.service-card h3 {
  font-size: 48rpx;
  margin-bottom: 30rpx;
  color: var(--primary-color);
}

.service-card p {
  color: var(--light-text);
  margin-bottom: 40rpx;
  line-height: 1.6;
}

.portfolio-item {
  background: white;
  border-radius: 30rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.portfolio-item:hover {
  transform: translateY(-20rpx);
  box-shadow: 0 30rpx 80rpx rgba(0, 0, 0, 0.2);
}

.portfolio-image {
  height: 400rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.portfolio-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.portfolio-info {
  padding: 40rpx;
}

.portfolio-info h4 {
  font-size: 36rpx;
  margin-bottom: 20rpx;
  color: var(--primary-color);
}

.portfolio-info p {
  color: var(--light-text);
  font-size: 28rpx;
}

.portfolio-note {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #f0f0f0;
}

.contact-item {
  display: flex;
  align-items: center;
  gap: 40rpx;
  background: var(--light-bg);
  padding: 60rpx;
  border-radius: 30rpx;
  margin-bottom: 30rpx;
}

.contact-icon {
  font-size: 100rpx;
}

.contact-details h3 {
  font-size: 40rpx;
  margin-bottom: 20rpx;
  color: var(--primary-color);
}

.contact-details p {
  color: var(--light-text);
  margin-bottom: 30rpx;
}

.btn-copy {
  background: var(--gradient);
  color: white;
  border: none;
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  cursor: pointer;
  font-weight: 600;
  transition: all 0.3s ease;
}

.btn-copy:hover {
  transform: scale(1.05);
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.2);
}

.form-group {
  margin-bottom: 50rpx;
}

.form-group label {
  display: block;
  margin-bottom: 16rpx;
  font-weight: 600;
  color: var(--text-color);
}

.form-group input,
.form-group select,
.form-group textarea {
  width: 100%;
  padding: 24rpx 30rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  font-size: 32rpx;
  transition: border-color 0.3s ease;
  font-family: inherit;
}

.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus {
  outline: none;
  border-color: var(--primary-color);
}

.btn-submit {
  width: 100%;
  background: var(--gradient);
  color: white;
  border: none;
  padding: 30rpx;
  border-radius: 16rpx;
  font-size: 36rpx;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
}

.btn-submit:hover {
  transform: translateY(-6rpx);
  box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.2);
}

.back-to-top {
  position: fixed;
  bottom: 60rpx;
  right: 60rpx;
  width: 100rpx;
  height: 100rpx;
  background: var(--gradient);
  color: white;
  border: none;
  border-radius: 50%;
  font-size: 48rpx;
  cursor: pointer;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-to-top.active {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}

.modal {
  display: none;
  position: fixed;
  z-index: 1000;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  overflow: auto;
  background-color: rgba(0, 0, 0, 0.9);
  align-items: center;
  justify-content: center;
}

.modal.show {
  display: flex;
}

.modal-content {
  position: relative;
  max-width: 90%;
  max-height: 90%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content img {
  width: 100%;
  height: auto;
  max-height: 80vh;
  object-fit: contain;
}

.close-modal {
  position: absolute;
  top: -80rpx;
  right: 0;
  color: white;
  font-size: 80rpx;
  font-weight: bold;
  cursor: pointer;
  transition: color 0.3s ease;
}

.close-modal:hover,
.close-modal:focus {
  color: var(--primary-color);
  text-decoration: none;
}

/* 响应式设计 */
@media (max-width: 768px) {
  .section-title {
    font-size: 56rpx;
  }
  
  .btn {
    padding: 20rpx 50rpx;
    font-size: 28rpx;
  }
  
  .service-card {
    padding: 60rpx 40rpx;
  }
  
  .contact-item {
    flex-direction: column;
    text-align: center;
  }
  
  .contact-icon {
    margin-bottom: 20rpx;
  }
}